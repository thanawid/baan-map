rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Baan-Map: ให้เฉพาะผู้ที่ล็อกอินแล้วอ่าน/เขียนข้อมูลบ้านได้
    match /municipalities/{municipalityId}/houses/{houseId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // ปิดเส้นทางอื่นทั้งหมดก่อน ปลอดภัยกว่าเปิดกว้าง
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
